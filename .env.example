# Postgres (Neon) — use the pooled connection string for serverless
DATABASE_URL=postgresql+psycopg://user:password@host/dbname?sslmode=require

# Session JWT — generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me

# Cron auth — generate similarly
CRON_SECRET=change-me

# MSG91 WhatsApp Business API
MSG91_AUTH_KEY=
MSG91_WHATSAPP_INTEGRATED_NUMBER=
MSG91_WHATSAPP_NAMESPACE=

# Cloudflare Turnstile (bot defense on /signup + /login).
# Create at https://dash.cloudflare.com/?to=/:account/turnstile and paste both
# values here. Leave blank to disable — signup/login still work, just unprotected.
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Environment: dev | preview | production
APP_ENV=dev

# Default clinic timezone (display only — storage is UTC)
CLINIC_TZ=Asia/Kolkata
