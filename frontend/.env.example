# Required
DATABASE_URL=postgresql://USER:PASS@HOST/DB?sslmode=require
# Use a SEPARATE Neon branch from the Python stack while evaluating this branch
# so the two stacks don't share rows. Schema is identical — swapping is just an
# env flip. Neon supports branching natively (each branch has its own URL).
SECRET_KEY=change-this-to-a-32-plus-character-random-string-please

# Optional
CLINIC_TZ=Asia/Kolkata

# MSG91 WhatsApp (leave blank in dev — lib/whatsapp.ts no-ops and console-logs)
MSG91_AUTHKEY=
MSG91_TEMPLATE_NAMESPACE=
MSG91_INTEGRATED_NUMBER=

# Cloudflare Turnstile (leave blank to disable bot-check on signup)
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Legacy — used only by the marketing landing CTAs that deep-link to the Python
# dashboard. Now that the dashboard lives here too, leave this commented out or
# point it at this app's own origin.
# NEXT_PUBLIC_APP_URL=https://baariprod.vercel.app
