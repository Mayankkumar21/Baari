{
  "name": "baari-promo",
  "version": "1.0.0",
  "private": true,
  "description": "Baari product-launch video, built with Remotion.",
  "scripts": {
    "start": "remotion studio src/index.ts",
    "build": "remotion render src/index.ts BaariPromo out/baari-promo.mp4",
    "build:square": "remotion render src/index.ts BaariPromoSquare out/baari-promo-square.mp4",
    "build:reel": "remotion render src/index.ts BaariPromoReel out/baari-promo-reel.mp4"
  },
  "dependencies": {
    "@remotion/cli": "^4.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "remotion": "^4.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "typescript": "^5.4.5"
  }
}
